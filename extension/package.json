{
  "name": "@apite/shopware6-user",
  "description": "Shopgate Connect Shopware 6 User extension created by Apite",
  "license": "Apache-2.0",
  "type": "commonjs",
  "repository": {
    "url": "https://gitlab.com/apite/shopgate/connect-engage/ext-shopware6-user"
  },
  "scripts": {
    "init": "npm i && cd ../frontend && npm i && cd ..",
    "utility:develop": "npm install --save ../../shopware6-utility",
    "backend": "node -r dotenv/config $(which sgconnect) backend start",
    "backend:dev": "node -r dotenv/config $(which sgconnect) backend start --inspect",
    "frontend": "sgconnect frontend start",
    "test:unit": "jest"
  },
  "dependencies": {
    "@apite/shopware6-utility": "^1.1.1",
    "@shopware-pwa/shopware-6-client": "^1.6.1",
    "nanoid": "2.1.11"
  },
  "devDependencies": {
    "@shopware-pwa/commons": "^1.3.0",
    "@types/node": "^17.0.19",
    "@types/bunyan": "^1.8.8",
    "@types/jest": "^29.2.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.16.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.2.1",
    "nyc": "15.1.0",
    "standard": "^17.0.0"
  }
}
